generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String             @id @default(uuid()) @db.Uuid
  email                    String             @unique
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  freeGenerationsRemaining Int                @default(1)
  generationCredits        Int                @default(0)
  billingPlan              String             @default("free")
  subscriptionStatus       String             @default("none")
  stripeCustomerId         String?            @unique
  passwordHash             String?
  passwordSalt             String?
  passwordIterations       Int?
  tabletops                Tabletop[]
  authSessions             AuthSession[]
  loginCodes               LoginCode[]
  aiRuns                   AiRun[]
  billingEvents            BillingEvent[]
  generationUsages         GenerationUsage[]
  paidCreditLedger         PaidCreditLedger[]
  subscriptions            Subscription[]

  @@map("users")
}

model Tabletop {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String?           @db.Uuid
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  title            String
  status           String            @default("draft")
  generationSource String            @default("local")
  exerciseJson     Json?
  scenarioType     String?
  industry         String?
  maturityLevel    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  uploadedFiles    UploadedFile[]
  aiRuns           AiRun[]
  deletionLogs     DeletionLog[]
  generationUsages GenerationUsage[]

  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@map("tabletops")
}

model GenerationUsage {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tabletopId      String?   @db.Uuid
  tabletop        Tabletop? @relation(fields: [tabletopId], references: [id], onDelete: SetNull)
  entitlementType String
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([tabletopId])
  @@index([entitlementType])
  @@map("generation_usages")
}

model PaidCreditLedger {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta           Int
  reason          String
  stripeSessionId String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([reason])
  @@map("paid_credit_ledger")
}

model Subscription {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @db.Uuid
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             String    @default("stripe")
  stripeSubscriptionId String?   @unique
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  canceledAt           DateTime?

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model AuthSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("auth_sessions")
}

model LoginCode {
  id        String    @id @default(uuid()) @db.Uuid
  email     String
  userId    String?   @db.Uuid
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  @@index([email])
  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("login_codes")
}

model UploadedFile {
  id               String    @id @default(uuid()) @db.Uuid
  tabletopId       String    @db.Uuid
  tabletop         Tabletop  @relation(fields: [tabletopId], references: [id], onDelete: Cascade)
  blobContainer    String
  blobPath         String
  originalFilename String
  contentType      String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
  deleteStatus     String    @default("active")

  @@index([tabletopId])
  @@index([deleteStatus])
  @@index([deletedAt])
  @@map("uploaded_files")
}

model AiRun {
  id              String    @id @default(uuid()) @db.Uuid
  tabletopId      String    @db.Uuid
  tabletop        Tabletop  @relation(fields: [tabletopId], references: [id], onDelete: Cascade)
  userId          String?   @db.Uuid
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  model           String
  promptType      String
  status          String    @default("pending")
  inputTokens     Int?
  outputTokens    Int?
  costEstimateUsd Decimal?  @db.Decimal(10, 6)
  resultJson      Json?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([tabletopId])
  @@index([userId])
  @@index([promptType])
  @@index([status])
  @@map("ai_runs")
}

model BillingEvent {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @db.Uuid
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  stripeEventId String?  @unique
  eventType     String
  payloadJson   Json?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@map("billing_events")
}

model DeletionLog {
  id         String   @id @default(uuid()) @db.Uuid
  tabletopId String   @db.Uuid
  tabletop   Tabletop @relation(fields: [tabletopId], references: [id], onDelete: Cascade)
  deletedAt  DateTime @default(now())
  status     String
  notes      String?

  @@index([tabletopId])
  @@index([status])
  @@map("deletion_logs")
}
